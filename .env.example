# ════════════════════════════════════════════════════════════
# EduPilot — Template des variables d'environnement
# ➜ Copier ce fichier en .env et remplir les valeurs
# ════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=scolaire
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=gestion_scolaire
DATABASE_URL=postgresql+asyncpg://scolaire:CHANGE_ME@localhost:5432/gestion_scolaire
DATABASE_URL_SYNC=postgresql://scolaire:CHANGE_ME@localhost:5432/gestion_scolaire

# ── Sécurité & JWT ──────────────────────────────────────────
# ➜ Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_A_64_CHAR_HEX_KEY
JWT_SECRET_KEY=GENERATE_A_64_CHAR_HEX_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://127.0.0.1:5173

# ── ML Service ──────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5001
ML_CONFIDENCE_THRESHOLD=0.75
ML_API_KEY=internal-ml-key-change-in-prod

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Uploads ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ── Backend ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_ML_URL=http://localhost:5001

# ── Email SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@edupilot.ma

# ── École ───────────────────────────────────────────────────
SCHOOL_NAME=École Privée Multi-Niveaux
SCHOOL_CITY=Fès
ACADEMIC_YEAR=2024-2025
